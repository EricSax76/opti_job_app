rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isCandidate() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/candidates/$(request.auth.uid));
    }

    function isCompany() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/companies/$(request.auth.uid));
    }

    // ─── Fase 0 RBAC helpers ──────────────────────────────────────────

    function hasSecondFactor() {
      return isSignedIn()
        && request.auth.token.firebase.sign_in_second_factor is string
        && request.auth.token.firebase.sign_in_second_factor.size() > 0;
    }

    function tokenIsActiveRecruiter() {
      return isSignedIn()
        && request.auth.token.isRecruiter == true
        && request.auth.token.recruiterStatus == 'active'
        && hasSecondFactor();
    }

    function docIsActiveRecruiter() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/recruiters/$(request.auth.uid))
        && get(/databases/$(database)/documents/recruiters/$(request.auth.uid)).data.status == 'active'
        && hasSecondFactor();
    }

    function isRecruiter() {
      return tokenIsActiveRecruiter() || docIsActiveRecruiter();
    }

    function recruiterBelongsToCompany(companyId) {
      return companyId is string
        && companyId.size() > 0
        && ((tokenIsActiveRecruiter()
          && request.auth.token.companyId == companyId)
          || (docIsActiveRecruiter()
            && get(/databases/$(database)/documents/recruiters/$(request.auth.uid)).data.companyId == companyId));
    }

    function recruiterHasRole(companyId, roles) {
      return companyId is string
        && companyId.size() > 0
        && ((tokenIsActiveRecruiter()
          && request.auth.token.companyId == companyId
          && request.auth.token.recruiterRole in roles)
          || (docIsActiveRecruiter()
            && get(/databases/$(database)/documents/recruiters/$(request.auth.uid)).data.companyId == companyId
            && get(/databases/$(database)/documents/recruiters/$(request.auth.uid)).data.role in roles));
    }

    function recruiterCanManageOffers(companyId) {
      return recruiterHasRole(companyId, ['admin', 'recruiter']);
    }

    function recruiterCanScore(companyId) {
      return recruiterHasRole(companyId, ['admin', 'recruiter', 'hiring_manager', 'external_evaluator']);
    }

    function recruiterCanViewReports(companyId) {
      return recruiterHasRole(companyId, ['admin', 'recruiter', 'viewer', 'hiring_manager']);
    }

    function recruiterCanAccessCompanyData(companyId) {
      return recruiterHasRole(companyId, ['admin', 'recruiter', 'viewer', 'hiring_manager', 'external_evaluator']);
    }

    function recruiterCanAccessBlockedArchive(companyId) {
      return companyId is string
        && companyId.size() > 0
        && recruiterHasRole(companyId, ['legal', 'auditor']);
    }

    function isCompanyOrRecruiterForCompany(companyId) {
      return (isCompany() && request.auth.uid == companyId)
        || recruiterCanAccessCompanyData(companyId);
    }

    function offerCompanyUid(data) {
      return data.get('company_uid', data.get('companyUid', data.get('owner_uid', '')));
    }

    function applicationCompanyUid(data) {
      return data.get('company_uid', data.get('companyUid', ''));
    }

    match /users/{userId} {
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == request.auth.uid;
      allow read: if isSignedIn()
        && request.auth.uid == userId;
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    match /candidates/{candidateId} {
      allow create: if isSignedIn()
        && request.auth.uid == candidateId
        && request.resource.data.uid == request.auth.uid;
      allow read: if (isSignedIn()
          && request.auth.uid == candidateId
          && resource.data.uid == request.auth.uid)
        || isCompany();
      allow update, delete: if isSignedIn()
        && request.auth.uid == candidateId
        && resource.data.uid == request.auth.uid;

      match /curriculum/{curriculumId} {
        allow create, update, delete: if isSignedIn()
          && request.auth.uid == candidateId;
        allow read: if (isSignedIn() && request.auth.uid == candidateId)
          || isCompany();
      }

      match /cover_letter/{coverLetterId} {
        allow create, update, delete: if isSignedIn()
          && request.auth.uid == candidateId;
        allow read: if (isSignedIn() && request.auth.uid == candidateId)
          || isCompany();
      }

      match /verifiedCredentials/{credentialId} {
        // Solo Cloud Functions puede escribir credenciales verificadas EUDI
        // tras validación criptográfica (firma/issuer/exp/audience).
        allow create, update, delete: if false;
        allow read: if isSignedIn()
          && request.auth.uid == candidateId;
      }
    }

    match /companies/{companyId} {
      allow create: if isSignedIn() && request.auth.uid == companyId;
      allow read: if (isCompany() && request.auth.uid == companyId)
                    || recruiterBelongsToCompany(companyId);
      allow update, delete: if isCompany() && request.auth.uid == companyId;
    }

    match /catalog/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /catalog_municipios/{provinciaId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /pipelines/{pipelineId} {
      allow read: if (
          resource.data.isTemplate == true
          && (isCompany() || isRecruiter())
        )
        || (
          isCompany()
          && resource.data.companyId == request.auth.uid
        )
        || (
          isRecruiter()
          && recruiterBelongsToCompany(resource.data.companyId)
        );
      allow write: if (
          isCompany()
          && request.resource.data.companyId == request.auth.uid
        )
        || (
          isRecruiter()
          && recruiterCanManageOffers(request.resource.data.companyId)
        );
    }

    match /jobOffers/{offerId} {
      allow read: if isSignedIn();
      // Offer creation is enforced via Cloud Functions (createJobOfferSecure).
      allow create: if false;
      allow update, delete: if (isCompany() && request.auth.uid == offerCompanyUid(resource.data))
                            || recruiterCanManageOffers(offerCompanyUid(resource.data));
    }

    function isOfferOwner(offerId) {
      let offer = get(/databases/$(database)/documents/jobOffers/$(string(offerId)));
      let data = offer.data;
      return offer != null && (
        data.get('companyUid', '') == request.auth.uid ||
        data.get('company_uid', '') == request.auth.uid ||
        data.get('owner_uid', '') == request.auth.uid ||
        // Check for integer IDs converted to string if stored that way
        string(data.get('companyId', '')) == request.auth.uid ||
        string(data.get('company_id', '')) == request.auth.uid
      );
    }

    // ── LGPD Blind Review ─────────────────────────────────────────
    // Direct reads restricted to candidates (own application only).
    // Company owners, recruiters, and hiring managers access
    // applications through the getApplicationsForReview callable,
    // which uses Admin SDK (bypasses rules) and projects fields
    // according to the pipeline stage (blind → partial → full).
    match /applications/{applicationId} {
      allow create: if isCandidate()
        && (request.auth.uid == request.resource.data.candidateId
            || request.auth.uid == request.resource.data.candidate_uid);

      allow read: if isCandidate()
          && (request.auth.uid == resource.data.candidateId
              || request.auth.uid == resource.data.candidate_uid);

      allow update: if request.auth.uid == resource.data.companyUid
            || request.auth.uid == resource.data.company_uid
            || isOfferOwner(resource.data.get('jobOfferId', resource.data.get('job_offer_id', '')))
            || recruiterCanManageOffers(applicationCompanyUid(resource.data));

      allow delete: if false;
    }

    match /calendarEvents/{eventId} {
      allow create: if isSignedIn()
        && request.resource.data.owner_uid == request.auth.uid;
      allow read, update, delete: if isSignedIn()
        && resource.data.owner_uid == request.auth.uid;
    }
    match /interviews/{interviewId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if (isCompany() 
          && request.resource.data.companyUid == request.auth.uid
          && request.auth.uid in request.resource.data.participants)
        || (isRecruiter()
          && recruiterCanManageOffers(request.resource.data.companyUid)
          && request.auth.uid in request.resource.data.participants);
      allow update: if isSignedIn() 
          && request.auth.uid in resource.data.participants
          // Prevent participants from changing immutable fields like applicationId or participants list
          && request.resource.data.applicationId == resource.data.applicationId
          && request.resource.data.participants == resource.data.participants;

      match /messages/{messageId} {
        allow read: if isSignedIn() 
            && request.auth.uid in get(/databases/$(database)/documents/interviews/$(interviewId)).data.participants;
        allow create: if isSignedIn()
            && request.auth.uid in get(/databases/$(database)/documents/interviews/$(interviewId)).data.participants
            && request.resource.data.senderUid == request.auth.uid;
      }
    }

    // ─── Fase 0 RBAC: Recruiters & Invitations ─────────────────────────────────

    match /recruiters/{uid} {
      // Puede leer su propio doc o cualquier reclutador activo de la misma empresa
      allow read: if (isSignedIn() && request.auth.uid == uid)
                    || (isRecruiter() && recruiterBelongsToCompany(resource.data.companyId));
      // Las escrituras son gestionadas exclusivamente por Cloud Functions
      allow write: if false;
    }

    match /invitations/{code} {
      // Los reclutadores pueden leer invitaciones (para mostrar código generado)
      allow read: if isRecruiter() && recruiterBelongsToCompany(resource.data.companyId);
      // Las escrituras son gestionadas exclusivamente por Cloud Functions
      allow write: if false;
    }

    match /scorecardTemplates/{templateId} {
      allow read: if (isCompany() && request.auth.uid == resource.data.companyId)
                    || recruiterBelongsToCompany(resource.data.companyId);
      allow write: if isCompany() || recruiterCanManageOffers(request.resource.data.companyId);
    }

    match /evaluations/{evaluationId} {
      allow read: if isCompany() || recruiterBelongsToCompany(resource.data.companyId);
      allow create: if isCompany() || recruiterCanScore(request.resource.data.companyId);
      allow update: if (isCompany() && request.auth.uid == resource.data.companyId) || 
                      (isRecruiter()
                        && request.auth.uid == resource.data.evaluatorUid
                        && recruiterBelongsToCompany(resource.data.companyId));
    }

    match /approvals/{approvalId} {
      allow read: if isCompany() || recruiterBelongsToCompany(resource.data.companyId);
      allow create: if isCompany() || recruiterHasRole(request.resource.data.companyId, ['admin', 'recruiter', 'hiring_manager']);
      allow update: if isCompany() || recruiterBelongsToCompany(resource.data.companyId);
    }

    // ─── Fase 4: Skills ───────────────────────────────────────────────

    match /skillsTaxonomy/{skillId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ─── Fase 5: CRM Talent Pool ──────────────────────────────────────

    match /talentPools/{poolId} {
      allow read: if isCompany() || recruiterBelongsToCompany(resource.data.companyId);
      allow create: if (isCompany() && request.resource.data.companyId == request.auth.uid)
        || recruiterCanManageOffers(request.resource.data.companyId);
      allow update, delete: if (isCompany() && request.auth.uid == poolId) || 
                              recruiterHasRole(resource.data.companyId, ['admin', 'recruiter']);

      match /members/{candidateUid} {
        allow read: if isCompany() || recruiterBelongsToCompany(get(/databases/$(database)/documents/talentPools/$(poolId)).data.companyId);
        // Writing is mostly via Cloud Functions, but allow company/recruiter for tags
        allow write: if isCompany() || recruiterBelongsToCompany(get(/databases/$(database)/documents/talentPools/$(poolId)).data.companyId);
      }
    }

    match /candidateNotes/{noteId} {
      allow read: if isCompany() || recruiterBelongsToCompany(resource.data.companyId);
      allow create: if (isCompany() && request.resource.data.companyId == request.auth.uid)
        || (isRecruiter()
          && request.auth.uid == request.resource.data.recruiterUid
          && recruiterBelongsToCompany(request.resource.data.companyId));
      allow update, delete: if (isCompany() && request.auth.uid == resource.data.companyId) || 
                              (isRecruiter() && request.auth.uid == resource.data.recruiterUid);
    }

    match /candidateEmbeddings/{candidateUid} {
      // Los embeddings de candidato se generan y actualizan solo en backend.
      // Lectura limitada al titular para transparencia/portabilidad.
      allow read: if isSignedIn() && request.auth.uid == candidateUid;
      allow write: if false;
    }

    match /aiDecisionLogs/{logId} {
      // Derecho a explicación: candidato dueño, empresa propietaria o perfiles autorizados.
      allow read: if (isSignedIn() && request.auth.uid == resource.data.candidateUid)
        || (isCompany() && request.auth.uid == resource.data.companyId)
        || recruiterCanViewReports(resource.data.companyId)
        || recruiterCanAccessBlockedArchive(resource.data.companyId);
      allow write: if false;
    }

    // ─── Fase 6: Compliance ───────────────────────────────────────────

    match /auditLogs/{logId} {
      // Solo lectura para la empresa auditada o perfiles legales/auditoría.
      allow read: if (isCompany() && resource.data.companyId == request.auth.uid)
        || recruiterCanAccessBlockedArchive(resource.data.companyId);
      allow write: if false; // Solo por Cloud Functions o internamente
    }

    match /blockedArchive/{archiveId} {
      // Archivo bloqueado: acceso exclusivo para rol legal/auditoría.
      allow read: if recruiterCanAccessBlockedArchive(resource.data.companyId);
      allow write: if false;
    }

    match /dataRequests/{requestId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.candidateUid || isCompany());
      allow create: if isCandidate() && request.auth.uid == request.resource.data.candidateUid;
      allow update: if isCompany(); // Solo resolutor
    }

    match /consentRecords/{recordId} {
      allow read: if isSignedIn() && (
          request.auth.uid == resource.data.candidateUid
          || isCompany()
          || recruiterCanViewReports(resource.data.companyId)
        );
      // Immutable consent records are written only by backend callables.
      allow create, update, delete: if false;
    }

    match /salaryBenchmarks/{benchmarkId} {
      allow read: if (isCompany() && request.auth.uid == resource.data.companyId)
                    || recruiterCanViewReports(resource.data.companyId);
      allow write: if (isCompany() && request.auth.uid == request.resource.data.companyId)
                    || recruiterCanManageOffers(request.resource.data.companyId);
    }

    match /salaryGapAlerts/{alertId} {
      allow read: if (isCompany() && request.auth.uid == resource.data.companyId)
                    || recruiterCanViewReports(resource.data.companyId);
      allow write: if false;
    }

    match /multipostingPublications/{publicationId} {
      allow read: if (isCompany() && request.auth.uid == resource.data.companyId)
                    || recruiterCanViewReports(resource.data.companyId)
                    || recruiterCanManageOffers(resource.data.companyId);
      allow write: if false;
    }

    // ─── Fase P2: EUDI selective disclosure + qualified signature ─────────────────

    match /credentialProofs/{proofId} {
      allow read: if isSignedIn() && (
          request.auth.uid == resource.data.get('candidateUid', resource.data.get('candidate_uid', ''))
          || isCompanyOrRecruiterForCompany(resource.data.get('companyUid', resource.data.get('company_uid', '')))
        );
      allow write: if false;
    }

    match /credentialProofShares/{proofId} {
      allow read: if isSignedIn() && (
          request.auth.uid == resource.data.get('candidateUid', resource.data.get('candidate_uid', ''))
          || isCompanyOrRecruiterForCompany(resource.data.get('companyUid', resource.data.get('company_uid', '')))
        );
      allow write: if false;
    }

    match /offerSignatureRequests/{requestId} {
      allow read: if isSignedIn() && (
          request.auth.uid == resource.data.get('candidateUid', resource.data.get('candidate_uid', ''))
          || isCompanyOrRecruiterForCompany(resource.data.get('companyUid', resource.data.get('company_uid', '')))
        );
      allow write: if false;
    }

    match /qualifiedSignatures/{signatureId} {
      allow read: if isSignedIn() && (
          request.auth.uid == resource.data.get('candidateUid', resource.data.get('candidate_uid', ''))
          || isCompanyOrRecruiterForCompany(resource.data.get('companyUid', resource.data.get('company_uid', '')))
        );
      allow write: if false;
    }

    // ─── Fase 7: Analytics ────────────────────────────────────────────

    match /analytics/{companyId} {
      allow read: if (isCompany() && companyId == request.auth.uid)
                    || recruiterCanViewReports(companyId);
      // Las escrituras las hace el sistema (Cloud Functions)
      allow write: if false;

      match /monthly/{period} {
        allow read: if (isCompany() && companyId == request.auth.uid)
                      || recruiterCanViewReports(companyId);
      }
    }

    match /performanceDashboards/{dashboardId} {
      allow read: if (isCompany() && resource.data.companyId == request.auth.uid)
                    || recruiterCanViewReports(resource.data.companyId);
      allow write: if false;
    }
  }
}
