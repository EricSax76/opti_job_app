rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isCandidate() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/candidates/$(request.auth.uid));
    }

    function isCompany() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/companies/$(request.auth.uid));
    }

    // ─── Fase 0 RBAC helpers ──────────────────────────────────────────

    function isRecruiter() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/recruiters/$(request.auth.uid));
    }

    function recruiterBelongsToCompany(companyId) {
      return isRecruiter() &&
        get(/databases/$(database)/documents/recruiters/$(request.auth.uid)).data.companyId == companyId;
    }

    function recruiterHasRole(companyId, roles) {
      return recruiterBelongsToCompany(companyId) &&
        get(/databases/$(database)/documents/recruiters/$(request.auth.uid)).data.role in roles &&
        get(/databases/$(database)/documents/recruiters/$(request.auth.uid)).data.status == 'active';
    }

    match /candidates/{candidateId} {
      allow create: if isSignedIn()
        && request.auth.uid == candidateId
        && request.resource.data.uid == request.auth.uid;
      allow read: if (isSignedIn()
          && request.auth.uid == candidateId
          && resource.data.uid == request.auth.uid)
        || isCompany();
      allow update, delete: if isSignedIn()
        && request.auth.uid == candidateId
        && resource.data.uid == request.auth.uid;

      match /curriculum/{curriculumId} {
        allow create, update, delete: if isSignedIn()
          && request.auth.uid == candidateId;
        allow read: if (isSignedIn() && request.auth.uid == candidateId)
          || isCompany();
      }

      match /cover_letter/{coverLetterId} {
        allow create, update, delete: if isSignedIn()
          && request.auth.uid == candidateId;
        allow read: if (isSignedIn() && request.auth.uid == candidateId)
          || isCompany();
      }
    }

    match /companies/{companyId} {
      allow create: if isSignedIn() && request.auth.uid == companyId;
      allow read: if (isCompany() && request.auth.uid == companyId)
                    || recruiterBelongsToCompany(companyId);
      allow update, delete: if isCompany() && request.auth.uid == companyId;
    }

    match /catalog/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /catalog_municipios/{provinciaId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /pipelines/{pipelineId} {
      allow read: if isCompany() && exists(/databases/$(database)/documents/companies/$(request.auth.uid)) && resource.data.companyId == request.auth.uid ||
                     isRecruiter() && recruiterBelongsToCompany(resource.data.companyId);
      allow write: if isCompany() && exists(/databases/$(database)/documents/companies/$(request.auth.uid)) && request.resource.data.companyId == request.auth.uid ||
                      isRecruiter() && recruiterBelongsToCompany(request.resource.data.companyId) && recruiterHasRole('admin', 'recruiter');
    }

    match /jobOffers/{offerId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isCompany()
        || recruiterHasRole(resource.data.get('companyUid', resource.data.get('company_uid', '')), ['admin', 'recruiter']);
    }

    function isOfferOwner(offerId) {
      let offer = get(/databases/$(database)/documents/jobOffers/$(string(offerId)));
      let data = offer.data;
      return offer != null && (
        data.get('companyUid', '') == request.auth.uid ||
        data.get('company_uid', '') == request.auth.uid ||
        data.get('owner_uid', '') == request.auth.uid ||
        // Check for integer IDs converted to string if stored that way
        string(data.get('companyId', '')) == request.auth.uid ||
        string(data.get('company_id', '')) == request.auth.uid
      );
    }

    match /applications/{applicationId} {
      allow create: if isCandidate()
        && (request.auth.uid == request.resource.data.candidateId
            || request.auth.uid == request.resource.data.candidate_uid);

      allow read: if (isCandidate()
          && (request.auth.uid == resource.data.candidateId
              || request.auth.uid == resource.data.candidate_uid))
        || (request.auth.uid == resource.data.companyUid)
        || (request.auth.uid == resource.data.company_uid)
        || isOfferOwner(resource.data.get('jobOfferId', resource.data.get('job_offer_id', '')));

      allow update: if request.auth.uid == resource.data.companyUid
            || request.auth.uid == resource.data.company_uid
            || isOfferOwner(resource.data.get('jobOfferId', resource.data.get('job_offer_id', '')));

      allow delete: if false; // Deletion is not allowed for now.
    }

    match /calendarEvents/{eventId} {
      allow create: if isSignedIn()
        && request.resource.data.owner_uid == request.auth.uid;
      allow read, update, delete: if isSignedIn()
        && resource.data.owner_uid == request.auth.uid;
    }
    match /interviews/{interviewId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isCompany() 
          && request.resource.data.companyUid == request.auth.uid
          && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() 
          && request.auth.uid in resource.data.participants
          // Prevent participants from changing immutable fields like applicationId or participants list
          && request.resource.data.applicationId == resource.data.applicationId
          && request.resource.data.participants == resource.data.participants;

      match /messages/{messageId} {
        allow read: if isSignedIn() 
            && request.auth.uid in get(/databases/$(database)/documents/interviews/$(interviewId)).data.participants;
        allow create: if isSignedIn()
            && request.auth.uid in get(/databases/$(database)/documents/interviews/$(interviewId)).data.participants
            && request.resource.data.senderUid == request.auth.uid;
      }
    }

    // ─── Fase 0 RBAC: Recruiters & Invitations ─────────────────────────────────

    match /recruiters/{uid} {
      // Puede leer su propio doc o cualquier reclutador activo de la misma empresa
      allow read: if (isSignedIn() && request.auth.uid == uid)
                    || isRecruiter();
      // Las escrituras son gestionadas exclusivamente por Cloud Functions
      allow write: if false;
    }

    match /invitations/{code} {
      // Los reclutadores pueden leer invitaciones (para mostrar código generado)
      allow read: if isRecruiter();
      // Las escrituras son gestionadas exclusivamente por Cloud Functions
      allow write: if false;
    }

    match /scorecardTemplates/{templateId} {
      allow read: if isCompany() || isRecruiter();
      allow write: if isCompany() || recruiterHasRole(request.resource.data.companyId, ['admin', 'recruiter']);
    }

    match /evaluations/{evaluationId} {
      allow read: if isCompany() || recruiterBelongsToCompany(resource.data.companyId);
      allow create: if isCompany() || isRecruiter();
      allow update: if (isCompany() && request.auth.uid == resource.data.companyId) || 
                      (isRecruiter() && request.auth.uid == resource.data.evaluatorUid);
    }

    match /approvals/{approvalId} {
      allow read: if isCompany() || recruiterBelongsToCompany(resource.data.companyId);
      allow create: if isCompany() || recruiterHasRole(request.resource.data.companyId, ['admin', 'recruiter']);
      allow update: if isCompany() || isRecruiter();
    }

    // ─── Fase 4: Skills ───────────────────────────────────────────────

    match /skillsTaxonomy/{skillId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ─── Fase 5: CRM Talent Pool ──────────────────────────────────────

    match /talentPools/{poolId} {
      allow read: if isCompany() || recruiterBelongsToCompany(resource.data.companyId);
      allow create: if isCompany() || isRecruiter();
      allow update, delete: if (isCompany() && request.auth.uid == poolId) || 
                              recruiterHasRole(resource.data.companyId, ['admin', 'recruiter']);

      match /members/{candidateUid} {
        allow read: if isCompany() || recruiterBelongsToCompany(get(/databases/$(database)/documents/talentPools/$(poolId)).data.companyId);
        // Writing is mostly via Cloud Functions, but allow company/recruiter for tags
        allow write: if isCompany() || recruiterBelongsToCompany(get(/databases/$(database)/documents/talentPools/$(poolId)).data.companyId);
      }
    }

    match /candidateNotes/{noteId} {
      allow read: if isCompany() || recruiterBelongsToCompany(resource.data.companyId);
      allow create: if isCompany() || isRecruiter();
      allow update, delete: if (isCompany() && request.auth.uid == resource.data.companyId) || 
                              (isRecruiter() && request.auth.uid == resource.data.recruiterUid);
    }

    // ─── Fase 6: Compliance ───────────────────────────────────────────

    match /auditLogs/{logId} {
      // Solo lectura para admins o la propia empresa auditada (según lógica de negocio)
      allow read: if isCompany() && resource.data.companyId == request.auth.uid;
      allow write: if false; // Solo por Cloud Functions o internamente
    }

    match /dataRequests/{requestId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.candidateUid || isCompany());
      allow create: if isCandidate() && request.auth.uid == request.resource.data.candidateUid;
      allow update: if isCompany(); // Solo resolutor
    }

    match /consentRecords/{recordId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.candidateUid || isCompany());
      allow write: if isCandidate() && request.auth.uid == request.resource.data.candidateUid;
    }

    // ─── Fase 7: Analytics ────────────────────────────────────────────

    match /analytics/{companyId} {
      allow read: if isCompany() && companyId == request.auth.uid;
      // Las escrituras las hace el sistema (Cloud Functions)
      allow write: if false;

      match /monthly/{period} {
        allow read: if isCompany() && companyId == request.auth.uid;
      }
    }
  }
}
